{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://socialpredict.local/spec-socialpredict-tasks/design-plan.schema.json",
  "title": "SocialPredict Design Plan",
  "description": "Canonical design-plan contract shared by software-designer agents and the architecture agent.",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "schema_version",
    "plan_uid",
    "title",
    "status",
    "source_context",
    "authors",
    "summary",
    "problem",
    "design_drivers",
    "current_state",
    "target_state",
    "decision_log",
    "workstreams",
    "risks",
    "open_questions",
    "next_steps"
  ],
  "properties": {
    "schema_version": {
      "type": "string",
      "const": "1.0"
    },
    "plan_uid": {
      "type": "string",
      "description": "Stable UUID for this design plan."
    },
    "title": {
      "type": "string",
      "minLength": 1
    },
    "status": {
      "type": "string",
      "enum": [
        "draft",
        "in_review",
        "approved",
        "superseded"
      ]
    },
    "created_at": {
      "type": "string",
      "format": "date-time"
    },
    "updated_at": {
      "type": "string",
      "format": "date-time"
    },
    "source_context": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "task_repo",
        "target_repo",
        "scope"
      ],
      "properties": {
        "task_repo": {
          "type": "string",
          "minLength": 1
        },
        "target_repo": {
          "type": "string",
          "minLength": 1
        },
        "scope": {
          "type": "array",
          "items": {
            "type": "string",
            "minLength": 1
          }
        },
        "source_documents": {
          "type": "array",
          "items": {
            "type": "string",
            "minLength": 1
          },
          "default": []
        },
        "related_task_uids": {
          "type": "array",
          "items": {
            "type": "string",
            "minLength": 1
          },
          "default": []
        }
      }
    },
    "authors": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": [
          "agent",
          "design_posture"
        ],
        "properties": {
          "agent": {
            "type": "string",
            "minLength": 1
          },
          "design_posture": {
            "type": "string",
            "enum": [
              "evans",
              "fowler",
              "martin",
              "hybrid",
              "other"
            ]
          },
          "notes": {
            "type": "string"
          }
        }
      }
    },
    "summary": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "one_sentence",
        "business_outcomes",
        "proposed_direction"
      ],
      "properties": {
        "one_sentence": {
          "type": "string",
          "minLength": 1
        },
        "business_outcomes": {
          "type": "array",
          "items": {
            "type": "string",
            "minLength": 1
          }
        },
        "proposed_direction": {
          "type": "string",
          "minLength": 1
        }
      }
    },
    "problem": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "statement",
        "why_now",
        "out_of_scope"
      ],
      "properties": {
        "statement": {
          "type": "string",
          "minLength": 1
        },
        "why_now": {
          "type": "string",
          "minLength": 1
        },
        "out_of_scope": {
          "type": "array",
          "items": {
            "type": "string",
            "minLength": 1
          }
        }
      }
    },
    "design_drivers": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "business_constraints": {
          "type": "array",
          "items": {
            "type": "string",
            "minLength": 1
          },
          "default": []
        },
        "architecture_drivers": {
          "type": "array",
          "items": {
            "type": "string",
            "minLength": 1
          },
          "default": []
        },
        "quality_attributes": {
          "type": "array",
          "items": {
            "type": "string",
            "minLength": 1
          },
          "default": []
        }
      }
    },
    "current_state": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "shape",
        "pain_points",
        "constraints"
      ],
      "properties": {
        "shape": {
          "type": "string",
          "minLength": 1
        },
        "pain_points": {
          "type": "array",
          "items": {
            "type": "string",
            "minLength": 1
          }
        },
        "constraints": {
          "type": "array",
          "items": {
            "type": "string",
            "minLength": 1
          }
        }
      }
    },
    "target_state": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "overview",
        "boundaries",
        "integration_seams"
      ],
      "properties": {
        "overview": {
          "type": "string",
          "minLength": 1
        },
        "boundaries": {
          "type": "array",
          "items": {
            "$ref": "#/$defs/boundary"
          }
        },
        "integration_seams": {
          "type": "array",
          "items": {
            "$ref": "#/$defs/integrationSeam"
          }
        },
        "ubiquitous_language": {
          "type": "array",
          "items": {
            "$ref": "#/$defs/glossaryTerm"
          },
          "default": []
        },
        "use_cases": {
          "type": "array",
          "items": {
            "$ref": "#/$defs/useCase"
          },
          "default": []
        },
        "domain_rules": {
          "type": "array",
          "items": {
            "$ref": "#/$defs/domainRule"
          },
          "default": []
        },
        "patterns": {
          "type": "array",
          "items": {
            "$ref": "#/$defs/pattern"
          },
          "default": []
        }
      }
    },
    "decision_log": {
      "type": "array",
      "items": {
        "$ref": "#/$defs/decision"
      }
    },
    "workstreams": {
      "type": "array",
      "items": {
        "$ref": "#/$defs/workstream"
      }
    },
    "risks": {
      "type": "array",
      "items": {
        "$ref": "#/$defs/risk"
      }
    },
    "open_questions": {
      "type": "array",
      "items": {
        "$ref": "#/$defs/question"
      }
    },
    "next_steps": {
      "type": "array",
      "items": {
        "type": "string",
        "minLength": 1
      }
    }
  },
  "$defs": {
    "boundary": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "name",
        "kind",
        "purpose",
        "owns",
        "does_not_own",
        "reason"
      ],
      "properties": {
        "name": {
          "type": "string",
          "minLength": 1
        },
        "kind": {
          "type": "string",
          "enum": [
            "bounded_context",
            "service",
            "module",
            "package",
            "integration_boundary"
          ]
        },
        "purpose": {
          "type": "string",
          "minLength": 1
        },
        "owns": {
          "type": "array",
          "items": {
            "type": "string",
            "minLength": 1
          }
        },
        "does_not_own": {
          "type": "array",
          "items": {
            "type": "string",
            "minLength": 1
          }
        },
        "upstream_dependencies": {
          "type": "array",
          "items": {
            "type": "string",
            "minLength": 1
          },
          "default": []
        },
        "downstream_dependencies": {
          "type": "array",
          "items": {
            "type": "string",
            "minLength": 1
          },
          "default": []
        },
        "reason": {
          "type": "string",
          "minLength": 1
        }
      }
    },
    "integrationSeam": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "name",
        "participants",
        "contract",
        "notes"
      ],
      "properties": {
        "name": {
          "type": "string",
          "minLength": 1
        },
        "participants": {
          "type": "array",
          "minItems": 2,
          "items": {
            "type": "string",
            "minLength": 1
          }
        },
        "contract": {
          "type": "string",
          "minLength": 1
        },
        "notes": {
          "type": "string",
          "minLength": 1
        }
      }
    },
    "glossaryTerm": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "term",
        "definition"
      ],
      "properties": {
        "term": {
          "type": "string",
          "minLength": 1
        },
        "definition": {
          "type": "string",
          "minLength": 1
        },
        "synonyms_to_avoid": {
          "type": "array",
          "items": {
            "type": "string",
            "minLength": 1
          },
          "default": []
        },
        "confused_with": {
          "type": "array",
          "items": {
            "type": "string",
            "minLength": 1
          },
          "default": []
        }
      }
    },
    "useCase": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "name",
        "actors",
        "goal"
      ],
      "properties": {
        "name": {
          "type": "string",
          "minLength": 1
        },
        "actors": {
          "type": "array",
          "items": {
            "type": "string",
            "minLength": 1
          }
        },
        "goal": {
          "type": "string",
          "minLength": 1
        },
        "notes": {
          "type": "string"
        }
      }
    },
    "domainRule": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "rule",
        "owner_boundary"
      ],
      "properties": {
        "rule": {
          "type": "string",
          "minLength": 1
        },
        "owner_boundary": {
          "type": "string",
          "minLength": 1
        },
        "reason": {
          "type": "string"
        }
      }
    },
    "pattern": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "name",
        "why"
      ],
      "properties": {
        "name": {
          "type": "string",
          "minLength": 1
        },
        "why": {
          "type": "string",
          "minLength": 1
        },
        "risks": {
          "type": "array",
          "items": {
            "type": "string",
            "minLength": 1
          },
          "default": []
        }
      }
    },
    "decision": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "id",
        "title",
        "status",
        "context",
        "decision",
        "consequences"
      ],
      "properties": {
        "id": {
          "type": "string",
          "minLength": 1
        },
        "title": {
          "type": "string",
          "minLength": 1
        },
        "status": {
          "type": "string",
          "enum": [
            "proposed",
            "accepted",
            "deferred",
            "rejected"
          ]
        },
        "context": {
          "type": "string",
          "minLength": 1
        },
        "decision": {
          "type": "string",
          "minLength": 1
        },
        "consequences": {
          "type": "array",
          "items": {
            "type": "string",
            "minLength": 1
          }
        }
      }
    },
    "workstream": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "name",
        "objective",
        "depends_on"
      ],
      "properties": {
        "name": {
          "type": "string",
          "minLength": 1
        },
        "objective": {
          "type": "string",
          "minLength": 1
        },
        "depends_on": {
          "type": "array",
          "items": {
            "type": "string",
            "minLength": 1
          }
        },
        "notes": {
          "type": "string"
        }
      }
    },
    "risk": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "severity",
        "statement",
        "mitigation"
      ],
      "properties": {
        "severity": {
          "type": "string",
          "enum": [
            "low",
            "medium",
            "high",
            "critical"
          ]
        },
        "statement": {
          "type": "string",
          "minLength": 1
        },
        "mitigation": {
          "type": "string",
          "minLength": 1
        }
      }
    },
    "question": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "question",
        "why_it_matters"
      ],
      "properties": {
        "question": {
          "type": "string",
          "minLength": 1
        },
        "why_it_matters": {
          "type": "string",
          "minLength": 1
        },
        "blocking": {
          "type": "boolean",
          "default": false
        }
      }
    }
  }
}
